{
  "expo": {
    "name": "MatchBuddy",
    "slug": "Matchbuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/matchbuddy-logo.png",
    "primaryColor": "#0C3314",
    "scheme": "matchbuddy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/matchbuddy-logo.png",
      "bundleIdentifier": "shop.matchbuddy",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "aps-environment": "development"
      }
    },
    "android": {
      "package": "shop.matchbuddy",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0C3314",
        "foregroundImage": "./assets/images/matchbuddy-logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow MatchBuddy to access your photos so you can add a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow MatchBuddy to use your location so we can find nearby fans and watch parties around you."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0C3314",
          "android": {
            "image": "./assets/images/matchbuddy-logo.png",
            "imageWidth": 160
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "shop.matchbuddy.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.shop.matchbuddy.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "ed560f4c-85ba-4c32-9f48-d6e82ddd8106"
      },
      "router": {}
    }
  }
}
